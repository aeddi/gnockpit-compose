# ---- gnockpit build ----

# Git repo + ref to build from (default: main branch of upstream repo)
# Examples:
#   GNOCKPIT_CONTEXT=https://github.com/gnoverse/gnockpit.git#main
#   GNOCKPIT_CONTEXT=https://github.com/yourfork/gnockpit.git#feature-branch
#   GNOCKPIT_CONTEXT=https://github.com/gnoverse/gnockpit.git#abc1234
# For local development, use a path instead:
#   GNOCKPIT_CONTEXT=../gnockpit
GNOCKPIT_CONTEXT=https://github.com/gnoverse/gnockpit.git#main

# ---- gnoland node ----

# RPC endpoint (host.docker.internal reaches the host on both Linux and macOS)
RPC_URL=http://host.docker.internal:26657

# Path to gnoland-data directory (relative to this compose file)
GNOLAND_DATA_DIR=./gnoland-data

# Path to genesis.json
GENESIS_PATH=./gnoland-data/genesis.json

# Docker container name of the gnoland service (for log streaming via docker logs)
GNOLAND_CONTAINER=gnoland

# ---- gnockpit settings ----

# Bind address and port
GNOCKPIT_LADDR=0.0.0.0
GNOCKPIT_PORT=8080

# Alert thresholds
CHAIN_STUCK_SECS=30
MISSED_BLOCKS_PCT=5

# Shoutrrr notification URLs — comma-separated list passed via --notify.
# See https://containrrr.dev/shoutrrr/latest/services/overview/
# Leave blank to disable. Examples:
#   NOTIFY_URLS=discord://token@webhookid
#   NOTIFY_URLS=discord://token@webhookid,telegram://token@telegram?chats=@channel
NOTIFY_URLS=

# ---- signal-cli-rest-api ----

# Bind address for signal-cli-rest-api (localhost only by default for security)
SIGNAL_API_LADDR=127.0.0.1
SIGNAL_API_PORT=8081
